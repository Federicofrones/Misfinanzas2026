rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{workspaceId}/{allPaths=**} {
      // Basic rule: only members of the workspace can read/write attachments
      // Note: Full member validation in storage rules requires firestore.get which can be expensive.
      // Often simpler to just check if authenticated and the path starts with their workspaceId.
      // For more security, we could use custom claims or allow only specific folder patterns.
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
